# ============================================================
#  Continuum — environment configuration
#  Copy to ".env" and fill in your keys.
# ============================================================

# ---------- Groq (the LLM, replaces Claude) ----------
# Get a free key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile      # reasoning: contradiction + Q&A
GROQ_FAST_MODEL=llama-3.1-8b-instant    # fast: per-utterance fact extraction

# ---------- Cognee memory layer ----------
USE_COGNEE=true
COGNEE_DATASET=continuum
COGNIFY_EVERY=4                          # build the graph every N utterances

# Cognee uses Groq for generation too (OpenAI-compatible endpoint).
# Embeddings can't run on Groq, so use a LOCAL embedding model (no extra key).
LLM_PROVIDER=groq
LLM_MODEL=groq/llama-3.3-70b-versatile
LLM_API_KEY=                             # same as GROQ_API_KEY
LLM_ENDPOINT=https://api.groq.com/openai/v1

EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384

# Self-host everything on one box (Best Use of Open Source track).
# Defaults to local SQLite + LanceDB if you leave these unset.
# GRAPH_DATABASE_PROVIDER=kuzu
# VECTOR_DB_PROVIDER=lancedb

# ---------- Server ----------
HOST=0.0.0.0
PORT=8000
